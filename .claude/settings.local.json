{
  "permissions": {
    "allow": [
      "Bash(packer version *)",
      "Bash(curl -fsSL https://releases.hashicorp.com/packer/index.json)",
      "Bash(python3 -c \"import json,sys; data=json.load\\(sys.stdin\\); versions=list\\(data['versions'].keys\\(\\)\\); print\\(sorted\\(versions\\)[-1]\\)\")",
      "Bash(curl -s https://checkpoint-api.hashicorp.com/v1/check/packer)",
      "Bash(python3 -c \"import json,sys; d=json.load\\(sys.stdin\\); print\\(d['current_version']\\)\")",
      "Read(//tmp/**)",
      "Bash(unzip -o packer.zip)",
      "Bash(sudo mv packer /usr/local/bin/packer)",
      "Bash(PATH=\"$HOME/.local/bin:$PATH\" packer init *)",
      "Bash(PATH=\"$HOME/.local/bin:$PATH\" packer validate *)"
    ]
  }
}
